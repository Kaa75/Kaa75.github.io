# Environment variables — copy to .env.local and fill in values
# See README.md for details

# Set to "true" to enable admin/demo mode for Hostivite (local dev only)
NEXT_PUBLIC_DEMO_MODE=false

# Contact form — serverless endpoint URL (optional; falls back to mailto)
NEXT_PUBLIC_CONTACT_ENDPOINT=

# Plausible analytics domain (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
